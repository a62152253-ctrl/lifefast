rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getPartnerUid() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.partnerUid;
    }

    function isPartnerOf(userId) {
      return isSignedIn() && getPartnerUid() == userId;
    }

    function canAccess(userId) {
      return isOwner(userId) || isPartnerOf(userId);
    }

    function isAdmin() {
      return isSignedIn()
          && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid))
          && get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == 'admin';
    }

    // --- 1. Tasks ---

    function isValidTask(data) {
      return data.title is string
          && data.title.size() > 0
          && data.title.size() <= 200
          && data.completed is bool
          && data.priority in ['low', 'medium', 'high', 'urgent']
          && data.userId is string
          && data.userId.size() <= 128
          && data.createdAt is timestamp;
    }

    match /tasks/{taskId} {
      allow get:    if canAccess(existing().userId);
      allow list:   if isSignedIn()
                    && (existing().userId == request.auth.uid
                        || isPartnerOf(existing().userId));
      allow create: if isSignedIn()
                    && isValidTask(incoming())
                    && incoming().userId == request.auth.uid
                    && incoming().createdAt == request.time;
      allow update: if canAccess(existing().userId)
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if canAccess(existing().userId);
    }

    // --- 2. Shopping Items ---

    function isValidShoppingItem(data) {
      return data.name is string
          && data.name.size() > 0
          && data.name.size() <= 100
          && data.checked is bool
          && data.addedBy is string
          && data.createdAt is timestamp;
    }

    match /shoppingItems/{itemId} {
      allow get:    if isSignedIn()
                    && (existing().addedBy == request.auth.uid
                        || isPartnerOf(existing().addedBy));
      allow list:   if isSignedIn()
                    && (existing().addedBy == request.auth.uid
                        || isPartnerOf(existing().addedBy));
      allow create: if isSignedIn()
                    && isValidShoppingItem(incoming())
                    && incoming().addedBy == request.auth.uid
                    && incoming().createdAt == request.time;
      allow update: if isSignedIn()
                    && (existing().addedBy == request.auth.uid
                        || isPartnerOf(existing().addedBy))
                    && incoming().addedBy == existing().addedBy
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn()
                    && (existing().addedBy == request.auth.uid
                        || isPartnerOf(existing().addedBy));
    }

    // --- 3. Habits ---

    function isValidHabit(data) {
      return data.name is string
          && data.name.size() > 0
          && data.name.size() <= 100
          && data.userId is string
          && data.completions is map
          && data.createdAt is timestamp;
    }

    match /habits/{habitId} {
      allow get:    if canAccess(existing().userId);
      allow list:   if isSignedIn()
                    && (existing().userId == request.auth.uid
                        || isPartnerOf(existing().userId));
      allow create: if isSignedIn()
                    && isValidHabit(incoming())
                    && incoming().userId == request.auth.uid
                    && incoming().createdAt == request.time;
      allow update: if canAccess(existing().userId)
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if canAccess(existing().userId);
    }

    // --- 4. Notes ---

    function isValidNote(data) {
      return data.content is string
          && data.content.size() > 0
          && data.content.size() <= 10000
          && data.userId is string
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
    }

    match /notes/{noteId} {
      allow get:    if canAccess(existing().userId);
      allow list:   if isSignedIn()
                    && (existing().userId == request.auth.uid
                        || isPartnerOf(existing().userId));
      allow create: if isSignedIn()
                    && isValidNote(incoming())
                    && incoming().userId == request.auth.uid
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      allow update: if canAccess(existing().userId)
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time;
      allow delete: if canAccess(existing().userId);
    }

    // --- 5. Budget ---

    function isValidBudget(data) {
      return data.description is string
          && data.description.size() > 0
          && data.description.size() <= 200
          && data.amount is number
          && data.type in ['income', 'expense']
          && data.userId is string
          && data.date is timestamp;
    }

    match /budget/{transactionId} {
      allow get:    if canAccess(existing().userId);
      allow list:   if isSignedIn()
                    && (existing().userId == request.auth.uid
                        || isPartnerOf(existing().userId));
      allow create: if isSignedIn()
                    && isValidBudget(incoming())
                    && incoming().userId == request.auth.uid
                    && incoming().date == request.time;
      allow update: if canAccess(existing().userId)
                    && incoming().userId == existing().userId
                    && incoming().date == existing().date;
      allow delete: if canAccess(existing().userId);
    }

    // --- 6. Plans ---

    function isValidPlan(data) {
      return data.time is string
          && data.time.size() == 5
          && data.activity is string
          && data.activity.size() > 0
          && data.activity.size() <= 200
          && data.userId is string
          && data.date is string
          && data.date.size() == 10
          && data.createdAt is timestamp;
    }

    match /plans/{planId} {
      allow get:    if canAccess(existing().userId);
      allow list:   if isSignedIn()
                    && (existing().userId == request.auth.uid
                        || isPartnerOf(existing().userId));
      allow create: if isSignedIn()
                    && isValidPlan(incoming())
                    && incoming().userId == request.auth.uid
                    && incoming().createdAt == request.time;
      allow update: if canAccess(existing().userId)
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if canAccess(existing().userId);
    }

    // --- 7. User Profiles ---

    match /userProfiles/{userId} {
      allow get:    if isSignedIn();
      allow list:   if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- 8. Invites ---

    match /invites/{inviteId} {
      allow read:   if isSignedIn()
                    && (resource.data.toEmail == request.auth.token.email
                        || resource.data.fromUid == request.auth.uid);
      allow create: if isSignedIn()
                    && incoming().fromUid == request.auth.uid;
      allow update: if isSignedIn()
                    && (existing().toEmail == request.auth.token.email
                        || existing().fromUid == request.auth.uid);
      allow delete: if isSignedIn()
                    && (resource.data.toEmail == request.auth.token.email
                        || resource.data.fromUid == request.auth.uid);
    }

    // --- 9. Messages (Chat) ---
    // Supports two schemas: chat (fromUid/toUid/chatId) and dashboard (senderId/participants)

    match /messages/{messageId} {
      allow get:    if isSignedIn()
                    && (request.auth.uid == existing().senderId
                        || request.auth.uid in existing().participants
                        || request.auth.uid == existing().fromUid
                        || request.auth.uid == existing().toUid);
      allow list:   if isSignedIn()
                    && (resource.data.senderId == request.auth.uid
                        || resource.data.fromUid == request.auth.uid
                        || resource.data.toUid == request.auth.uid
                        || (resource.data.participants is list
                            && request.auth.uid in resource.data.participants));
      allow create: if isSignedIn()
                    && incoming().content is string
                    && incoming().content.size() > 0
                    && incoming().content.size() <= 500
                    && (incoming().senderId == request.auth.uid
                        || incoming().fromUid == request.auth.uid);
      allow update: if isSignedIn()
                    && (existing().senderId == request.auth.uid
                        || request.auth.uid in existing().participants
                        || existing().fromUid == request.auth.uid
                        || existing().toUid == request.auth.uid);
      allow delete: if false;
    }

    // --- 10. Custom Navigation ---

    match /users/{userId}/customNav/{navId} {
      allow get,
            list:   if isOwner(userId);
      allow create: if isOwner(userId)
                    && incoming().userId == request.auth.uid
                    && incoming().isCustom == true;
      allow update: if isOwner(userId)
                    && incoming().userId == existing().userId
                    && incoming().isCustom == existing().isCustom;
      allow delete: if isOwner(userId);
    }

    // --- 11. Calendar Events ---

    function isValidCalendarEvent(data) {
      return data.title is string
          && data.title.size() > 0
          && data.title.size() <= 200
          && data.date is string
          && data.date.size() == 10
          && data.userId is string
          && data.createdAt is timestamp;
    }

    match /calendarEvents/{eventId} {
      allow get:    if canAccess(existing().userId);
      allow list:   if isSignedIn()
                    && (existing().userId == request.auth.uid
                        || isPartnerOf(existing().userId));
      allow create: if isSignedIn()
                    && isValidCalendarEvent(incoming())
                    && incoming().userId == request.auth.uid
                    && incoming().createdAt == request.time;
      allow update: if canAccess(existing().userId)
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if canAccess(existing().userId);
    }

    // --- 12. Shared Goals ---

    function isValidSharedGoal(data) {
      return data.title is string
          && data.title.size() > 0
          && data.title.size() <= 200
          && data.participants is list
          && data.participants.size() >= 2
          && data.type in ['challenge', 'monthly', 'weekly']
          && data.createdAt is timestamp;
    }

    match /sharedGoals/{goalId} {
      allow get:    if isSignedIn() && request.auth.uid in existing().participants;
      allow list:   if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn()
                    && isValidSharedGoal(incoming())
                    && request.auth.uid in incoming().participants
                    && incoming().createdAt == request.time;
      allow update: if isSignedIn()
                    && request.auth.uid in existing().participants
                    && incoming().participants == existing().participants
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn()
                    && request.auth.uid in existing().participants
                    && request.auth.uid == existing().participants[0];
    }

    // --- 13. Activity Log ---

    function isValidActivity(data) {
      return data.action is string
          && data.action.size() > 0
          && data.action.size() <= 100
          && data.userId is string
          && data.timestamp is timestamp;
    }

    match /activity/{activityId} {
      allow get:    if isOwner(existing().userId);
      allow list:   if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
                    && isValidActivity(incoming())
                    && incoming().userId == request.auth.uid
                    && incoming().timestamp == request.time;
      allow update,
            delete: if false;
    }

    // --- 14. Goals (personal) ---

    match /goals/{goalId} {
      allow get:    if canAccess(existing().userId);
      allow list:   if isSignedIn()
                    && (existing().userId == request.auth.uid
                        || isPartnerOf(existing().userId));
      allow create: if isSignedIn()
                    && incoming().userId == request.auth.uid;
      allow update: if canAccess(existing().userId)
                    && incoming().userId == existing().userId;
      allow delete: if canAccess(existing().userId);
    }

    // --- 15. Mood Entries ---

    match /moodEntries/{entryId} {
      allow get:    if isOwner(existing().userId);
      allow list:   if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isOwner(existing().userId)
                    && incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId);
    }

    // --- 16. Notifications ---

    match /notifications/{notificationId} {
      allow get:    if isOwner(existing().userId);
      allow list:   if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isOwner(existing().userId)
                    && incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId);
    }

    // --- 17. Meal Plans ---

    match /mealPlans/{planId} {
      allow get:    if isOwner(existing().userId);
      allow list:   if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isOwner(existing().userId)
                    && incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId);
    }

    // --- 20. Meals (MealPlanner component) ---

    match /meals/{mealId} {
      allow get:    if isOwner(existing().userId);
      allow list:   if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isOwner(existing().userId)
                    && incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId);
    }

    // --- 18. Stats ---

    match /stats/{userId} {
      allow read:   if isOwner(userId);
      allow write:  if isOwner(userId);
    }

    // --- 19. Week Stats ---

    match /weekStats/{userId} {
      allow read:   if isOwner(userId);
      allow write:  if isOwner(userId);
    }
  }
}
