rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // User Profiles - allow read for own profile
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Shopping Items - allow read/write for authenticated users
    match /shoppingItems/{itemId} {
      allow read, write: if isSignedIn();
    }
    
    // Plans - allow read/write for authenticated users
    match /plans/{planId} {
      allow read, write: if isSignedIn();
    }
    
    // Tasks - allow read/write for authenticated users
    match /tasks/{taskId} {
      allow read, write: if isSignedIn();
    }
    
    // Habits - allow read/write for authenticated users  
    match /habits/{habitId} {
      allow read, write: if isSignedIn();
    }
    
    // Custom Navigation - allow read/write for own data
    match /users/{userId}/customNav/{navId} {
      allow read, write: if isOwner(userId);
    }
    
    // Calendar Events - allow read/write for authenticated users
    match /calendarEvents/{eventId} {
      allow read, write: if isSignedIn();
    }
    
    // Shared Goals - allow read/write for authenticated users
    match /sharedGoals/{goalId} {
      allow read, write: if isSignedIn();
    }
    
    // Messages - allow read/write for authenticated users
    match /messages/{messageId} {
      allow read, write: if isSignedIn();
    }
    
    // Activity Log - allow read/write for authenticated users
    match /activity/{activityId} {
      allow read, write: if isSignedIn();
    }
    
    // Budget - allow read/write for authenticated users
    match /budget/{transactionId} {
      allow read, write: if isSignedIn();
    }
    
    // Notes - allow read/write for authenticated users
    match /notes/{noteId} {
      allow read, write: if isSignedIn();
    }
    
    // Invites - allow read/write for authenticated users
    match /invites/{inviteId} {
      allow read, write: if isSignedIn();
    }
  }
}
