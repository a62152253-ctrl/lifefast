rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access to authenticated users for their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow access to tasks for user and their partner
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }
    
    // Allow access to habits for user and their partner  
    match /habits/{habitId} {
      allow read, write: if request.auth != null;
    }
    
    // Allow access to other collections for authenticated users
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
